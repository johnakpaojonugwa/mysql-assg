{
  "baseURL": "http://localhost:5002",
  "authentication": {
    "type": "Bearer Token",
    "header": "Authorization",
    "format": "Bearer {accessToken}",
    "note": "Required for all endpoints except public product endpoints and auth endpoints"
  },
  "endpoints": [
    {
      "category": "Authentication",
      "prefix": "/api/auth",
      "endpoints": [
        {
          "method": "POST",
          "path": "/register",
          "fullPath": "/api/auth/register",
          "description": "Register a new user account",
          "requiresAuth": false,
          "role": "none",
          "rateLimit": "5 requests per 15 minutes",
          "requestBody": {
            "full_name": {
              "type": "string",
              "required": true,
              "example": "John Doe",
              "constraints": "2-100 characters"
            },
            "email": {
              "type": "string",
              "required": true,
              "example": "john@example.com",
              "constraints": "Valid email format, unique"
            },
            "password": {
              "type": "string",
              "required": true,
              "example": "SecurePass123!",
              "constraints": "8-72 chars, uppercase, lowercase, number, symbol"
            },
            "age": {
              "type": "integer",
              "required": false,
              "example": 25,
              "constraints": "0-100 or null"
            }
          },
          "response": {
            "success": true,
            "message": "User registered successfully",
            "data": {
              "userId": "USER_123456",
              "email": "john@example.com",
              "fullName": "John Doe",
              "role": "customer"
            }
          }
        },
        {
          "method": "POST",
          "path": "/login",
          "fullPath": "/api/auth/login",
          "description": "Login with email and password",
          "requiresAuth": false,
          "role": "none",
          "rateLimit": "5 requests per 15 minutes",
          "requestBody": {
            "email": {
              "type": "string",
              "required": true,
              "example": "john@example.com"
            },
            "password": {
              "type": "string",
              "required": true,
              "example": "SecurePass123!"
            }
          },
          "response": {
            "success": true,
            "message": "Login successful",
            "data": {
              "accessToken": "jwt_access_token",
              "refreshToken": "jwt_refresh_token",
              "user": {
                "userId": "USER_123456",
                "email": "john@example.com",
                "fullName": "John Doe",
                "role": "customer"
              }
            }
          }
        },
        {
          "method": "POST",
          "path": "/refresh",
          "fullPath": "/api/auth/refresh",
          "description": "Get a new access token using refresh token",
          "requiresAuth": false,
          "role": "none",
          "requestBody": {
            "refreshToken": {
              "type": "string",
              "required": true,
              "example": "jwt_refresh_token"
            }
          },
          "response": {
            "success": true,
            "message": "Token refreshed successfully",
            "data": {
              "accessToken": "new_jwt_access_token"
            }
          }
        },
        {
          "method": "POST",
          "path": "/logout",
          "fullPath": "/api/auth/logout",
          "description": "Logout and invalidate tokens",
          "requiresAuth": false,
          "role": "none",
          "requestBody": {
            "refreshToken": {
              "type": "string",
              "required": true,
              "example": "jwt_refresh_token"
            }
          },
          "response": {
            "success": true,
            "message": "Logout successful"
          }
        }
      ]
    },
    {
      "category": "Users (Self Service)",
      "prefix": "/api/users",
      "endpoints": [
        {
          "method": "GET",
          "path": "/me",
          "fullPath": "/api/users/me",
          "description": "Get current authenticated user's profile",
          "requiresAuth": true,
          "role": "any",
          "queryParams": {},
          "response": {
            "success": true,
            "data": {
              "userId": "USER_123456",
              "email": "john@example.com",
              "fullName": "John Doe",
              "age": 25,
              "role": "customer",
              "createdAt": "2025-01-15T10:30:00Z"
            }
          }
        },
        {
          "method": "PATCH",
          "path": "/me",
          "fullPath": "/api/users/me",
          "description": "Update current user's profile",
          "requiresAuth": true,
          "role": "any",
          "requestBody": {
            "full_name": {
              "type": "string",
              "required": false,
              "example": "Jane Doe",
              "constraints": "2-100 characters"
            },
            "age": {
              "type": "integer",
              "required": false,
              "example": 26,
              "constraints": "0-100 or null"
            }
          },
          "response": {
            "success": true,
            "message": "Profile updated successfully",
            "data": {
              "userId": "USER_123456",
              "fullName": "Jane Doe",
              "age": 26
            }
          }
        },
        {
          "method": "PATCH",
          "path": "/me/password",
          "fullPath": "/api/users/me/password",
          "description": "Change current user's password",
          "requiresAuth": true,
          "role": "any",
          "requestBody": {
            "current_password": {
              "type": "string",
              "required": true,
              "example": "OldPass123!"
            },
            "new_password": {
              "type": "string",
              "required": true,
              "example": "NewPass456!",
              "constraints": "8-72 chars, uppercase, lowercase, number, symbol"
            }
          },
          "response": {
            "success": true,
            "message": "Password changed successfully"
          }
        }
      ]
    },
    {
      "category": "Admin - User Management",
      "prefix": "/api/admin",
      "endpoints": [
        {
          "method": "GET",
          "path": "/users",
          "fullPath": "/api/admin/users",
          "description": "Get all users (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "queryParams": {
            "limit": {
              "type": "integer",
              "example": 10,
              "description": "Number of users to return"
            },
            "offset": {
              "type": "integer",
              "example": 0,
              "description": "Pagination offset"
            }
          },
          "response": {
            "success": true,
            "data": [
              {
                "userId": "USER_123456",
                "email": "john@example.com",
                "fullName": "John Doe",
                "age": 25,
                "role": "customer",
                "createdAt": "2025-01-15T10:30:00Z"
              }
            ]
          }
        },
        {
          "method": "GET",
          "path": "/users/:userId",
          "fullPath": "/api/admin/users/USER_123456",
          "description": "Get specific user by ID (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "pathParams": {
            "userId": {
              "type": "string",
              "required": true,
              "example": "USER_123456",
              "description": "The user ID to retrieve"
            }
          },
          "response": {
            "success": true,
            "data": {
              "userId": "USER_123456",
              "email": "john@example.com",
              "fullName": "John Doe",
              "age": 25,
              "role": "customer",
              "createdAt": "2025-01-15T10:30:00Z"
            }
          }
        },
        {
          "method": "POST",
          "path": "/users",
          "fullPath": "/api/admin/users",
          "description": "Create a new user (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "requestBody": {
            "full_name": {
              "type": "string",
              "required": true,
              "example": "Jane Doe",
              "constraints": "2-100 characters"
            },
            "email": {
              "type": "string",
              "required": true,
              "example": "jane@example.com",
              "constraints": "Valid email, unique"
            },
            "password": {
              "type": "string",
              "required": true,
              "example": "SecurePass123!",
              "constraints": "8-72 chars, uppercase, lowercase, number, symbol"
            },
            "role": {
              "type": "string",
              "required": false,
              "example": "customer",
              "constraints": "'customer' or 'admin', defaults to 'customer'"
            },
            "age": {
              "type": "integer",
              "required": false,
              "example": 28,
              "constraints": "0-100 or null"
            }
          },
          "response": {
            "success": true,
            "message": "User created successfully",
            "data": {
              "userId": "USER_789012",
              "email": "jane@example.com",
              "fullName": "Jane Doe",
              "role": "customer"
            }
          }
        },
        {
          "method": "PATCH",
          "path": "/users/:userId",
          "fullPath": "/api/admin/users/USER_123456",
          "description": "Update user by ID (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "pathParams": {
            "userId": {
              "type": "string",
              "required": true,
              "example": "USER_123456"
            }
          },
          "requestBody": {
            "full_name": {
              "type": "string",
              "required": false,
              "example": "John Updated"
            },
            "role": {
              "type": "string",
              "required": false,
              "example": "admin",
              "constraints": "'customer' or 'admin'"
            },
            "age": {
              "type": "integer",
              "required": false,
              "example": 26
            }
          },
          "response": {
            "success": true,
            "message": "User updated successfully"
          }
        },
        {
          "method": "DELETE",
          "path": "/users/:userId",
          "fullPath": "/api/admin/users/USER_123456",
          "description": "Delete user by ID (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "pathParams": {
            "userId": {
              "type": "string",
              "required": true,
              "example": "USER_123456"
            }
          },
          "response": {
            "success": true,
            "message": "User deleted successfully"
          }
        }
      ]
    },
