    {
      "category": "Orders",
      "prefix": "/api/orders",
      "requiresAuth": true,
      "endpoints": [
        {
          "method": "POST",
          "path": "/",
          "fullPath": "/api/orders",
          "description": "Create order from shopping cart",
          "requiresAuth": true,
          "role": "any",
          "rateLimit": "10 orders per 15 minutes per user",
          "requestBody": {
            "shippingAddress": {
              "type": "string",
              "required": true,
              "example": "123 Main St, City, State 12345"
            },
            "shippingCity": {
              "type": "string",
              "required": true,
              "example": "Springfield"
            },
            "shippingState": {
              "type": "string",
              "required": true,
              "example": "IL"
            },
            "shippingZip": {
              "type": "string",
              "required": true,
              "example": "62701"
            },
            "paymentMethod": {
              "type": "string",
              "required": true,
              "example": "credit_card",
              "constraints": "'credit_card', 'debit_card', 'paypal', etc."
            }
          },
          "response": {
            "success": true,
            "message": "Order created successfully",
            "data": {
              "orderId": "ORD_123456",
              "userId": "USER_123456",
              "totalAmount": 299.98,
              "status": "pending",
              "items": [
                {
                  "orderId": "OI_789012",
                  "productId": "PROD_123456",
                  "productName": "Wireless Headphones",
                  "quantity": 2,
                  "price": 149.99
                }
              ],
              "createdAt": "2025-01-15T10:30:00Z"
            }
          }
        },
        {
          "method": "GET",
          "path": "/",
          "fullPath": "/api/orders",
          "description": "Get orders (customers see their own, admins see all)",
          "requiresAuth": true,
          "role": "any",
          "queryParams": {
            "status": {
              "type": "string",
              "example": "pending",
              "description": "Filter by order status"
            },
            "limit": {
              "type": "integer",
              "example": 10
            },
            "offset": {
              "type": "integer",
              "example": 0
            }
          },
          "response": {
            "success": true,
            "data": [
              {
                "orderId": "ORD_123456",
                "userId": "USER_123456",
                "totalAmount": 299.98,
                "status": "pending",
                "createdAt": "2025-01-15T10:30:00Z"
              }
            ]
          }
        },
        {
          "method": "GET",
          "path": "/:orderId",
          "fullPath": "/api/orders/ORD_123456",
          "description": "Get specific order (customers see their own, admins see any)",
          "requiresAuth": true,
          "role": "any",
          "pathParams": {
            "orderId": {
              "type": "string",
              "required": true,
              "example": "ORD_123456"
            }
          },
          "response": {
            "success": true,
            "data": {
              "orderId": "ORD_123456",
              "userId": "USER_123456",
              "totalAmount": 299.98,
              "status": "pending",
              "items": [
                {
                  "orderId": "OI_789012",
                  "productId": "PROD_123456",
                  "quantity": 2,
                  "price": 149.99
                }
              ],
              "shippingAddress": "123 Main St, City, State 12345",
              "createdAt": "2025-01-15T10:30:00Z"
            }
          }
        },
        {
          "method": "GET",
          "path": "/:orderId/track",
          "fullPath": "/api/orders/ORD_123456/track",
          "description": "Track order status (customers see their own, admins see any)",
          "requiresAuth": true,
          "role": "any",
          "pathParams": {
            "orderId": {
              "type": "string",
              "required": true,
              "example": "ORD_123456"
            }
          },
          "response": {
            "success": true,
            "data": {
              "orderId": "ORD_123456",
              "status": "pending",
              "statusHistory": [
                {
                  "status": "pending",
                  "timestamp": "2025-01-15T10:30:00Z",
                  "description": "Order placed"
                },
                {
                  "status": "processing",
                  "timestamp": "2025-01-15T10:35:00Z",
                  "description": "Payment received"
                }
              ],
              "estimatedDelivery": "2025-01-22T23:59:59Z"
            }
          }
        },
        {
          "method": "PATCH",
          "path": "/:orderId/status",
          "fullPath": "/api/orders/ORD_123456/status",
          "description": "Update order status (admin only)",
          "requiresAuth": true,
          "role": "admin",
          "pathParams": {
            "orderId": {
              "type": "string",
              "required": true,
              "example": "ORD_123456"
            }
          },
          "requestBody": {
            "status": {
              "type": "string",
              "required": true,
              "example": "shipped",
              "constraints": "'pending', 'processing', 'shipped', 'delivered', 'cancelled'"
            },
            "notes": {
              "type": "string",
              "required": false,
              "example": "Package on its way"
            }
          },
          "response": {
            "success": true,
